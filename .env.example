# Optional — Logging
LOG_LEVEL=INFO
LOG_FORMAT=dev

# ----------------------------------------------------------------------
# Auth
# ----------------------------------------------------------------------
# Default is TRUE (fail-closed). When enabled and no tokens are configured,
# taskbrew auto-generates one at first boot and prints it to the log.
# Override to "false" ONLY for local development on loopback.
AUTH_ENABLED=true

# CORS — comma-separated origin allow-list. NEVER use "*" with
# allow_credentials (which the dashboard uses).
CORS_ORIGINS=http://localhost:8000,http://localhost:3000
